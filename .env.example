############################################################
## Studio Salaru – Job Note System (.env.example)
## TEMPLATE ONLY – COPY THIS TO ".env" AND FILL IN VALUES
############################################################

############################
## Application
############################

APP_NAME="Studio Salaru Internal Job Management System"
APP_ENV=local
APP_KEY=
APP_DEBUG=true

# URL that is used in links and redirects (Laravel helpers like url(), asset()).
APP_URL=http://localhost:8000

# Application timezone – also used for displaying times in the UI.
APP_TIMEZONE=Asia/Colombo

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# How maintenance mode is stored (file is fine for a single server / local dev).
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# Number of workers used by PHP’s built‑in web server (rarely needed).
# PHP_CLI_SERVER_WORKERS=4

# Cost factor for password hashing (higher = slower + more secure).
BCRYPT_ROUNDS=12


############################
## Logging
############################

# "stack" = combine multiple channels (configured in config/logging.php).
LOG_CHANNEL=stack
# "single" = write everything to a single log file (storage/logs/laravel.log).
LOG_STACK=single

LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug


############################
## Primary application database
## This is where ALL job system data is stored.
############################

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=studiosalaru_jobndb
DB_USERNAME=root
DB_PASSWORD=


############################
## Session & Authentication
############################

# Store sessions in the database so that logins survive PHP restarts.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null


############################
## Queues, Cache, Files
############################

# Broadcasting is only used for events; "log" is safe for this app.
BROADCAST_CONNECTION=log

# Default storage disk for uploaded files / exports.
FILESYSTEM_DISK=local

# Queues are used for background jobs (e.g. sync from POS).
QUEUE_CONNECTION=database

# Store cache data in the database (instead of file/redis).
CACHE_STORE=database
# CACHE_PREFIX=studio_salaru_


############################
## Redis / Memcached (optional)
############################

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379


############################
## Mail
############################

# "log" = emails are written to the log instead of being sent.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"


############################
## AWS / S3 (not required for this project)
############################

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false


############################
## Frontend (Vite)
############################

VITE_APP_NAME="${APP_NAME}"


############################
## Default Owner login (template)
## CHANGE THESE AFTER FIRST LOGIN.
############################

OWNER_EMAIL=owner@studiosalaru.com
OWNER_PASSWORD=password


############################
## Source POS database (READ ONLY)
## studiosalaru_datadb – XAMPP / POS DB
## Used by:
##   - jobs:sync-from-source
##   - Products / categories pages
## NEVER WRITE TO THIS DATABASE FROM THIS APP.
############################

DB_SOURCE_HOST=127.0.0.1
DB_SOURCE_PORT=3306
DB_SOURCE_DATABASE=studiosalaru_datadb
DB_SOURCE_USERNAME=root
DB_SOURCE_PASSWORD=
